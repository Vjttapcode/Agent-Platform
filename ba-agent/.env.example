# ----------------------------------------------------------------------------
# BA Agent — Environment Configuration
# Copy this file to ".env" and fill in your values:
#   Copy-Item .env.example .env   (Windows PowerShell)
#   copy .env.example .env        (Windows CMD)
#   cp .env.example .env          (macOS/Linux)
# ----------------------------------------------------------------------------

# Which LLM engine to use: "gemini" (FREE tier) or "anthropic".
LLM_PROVIDER=gemini

# --- Google Gemini (FREE) -----------------------------------------------------
# Get a FREE key (just a Google account, no card) at:
#   https://aistudio.google.com/apikey
GEMINI_API_KEY=AIza-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Free, fast model. Other options: gemini-2.5-pro, gemini-2.0-flash
GEMINI_MODEL=gemini-2.5-flash

# --- Anthropic Claude (paid — needs credits) ----------------------------------
# Used only when LLM_PROVIDER=anthropic. Key: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Options: claude-sonnet-4-6, claude-opus-4-8, claude-haiku-4-5-20251001
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- Shared -------------------------------------------------------------------
# Max output tokens per reply.
MAX_TOKENS=4096

# Max output tokens for document/SRS analysis (longer reviews).
ANALYZE_MAX_TOKENS=8192

# HTTP port for the web chat.
PORT=3000
