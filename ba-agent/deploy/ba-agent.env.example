# Copy to /etc/ba-agent.env on the server (chmod 600, owned by the service user).
# systemd reads this via EnvironmentFile.

LLM_PROVIDER=tokenrouter
TOKENROUTER_API_KEY=tr-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TOKENROUTER_MODEL=MiniMax-M3
TOKENROUTER_BASE_URL=https://api.tokenrouter.com/v1

# Persistent data OUTSIDE the deploy folder (survives redeploys):
DATA_DIR=/var/lib/ba-agent

PORT=3000
LOG_LEVEL=info
